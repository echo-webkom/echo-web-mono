{
  "name": "@echo-webkom/playwright",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test:e2e": "deno run -A --env-file ../../.env npm:playwright test",
    "test:e2e:ui": "deno run -A --env-file ../../.env npm:playwright test --ui-port 5555",
    "test:install": "deno run -A --env-file ../../.env npm:playwright install --with-deps",
    "test:report": "deno run -A --env-file ../../.env npm:playwright show-report",
    "lint": "deno run lint",
    "clean": "rm -rf node_modules playwright-report test-results .turbo"
  },
  "devDependencies": {
    "@playwright/test": "1.47.2",
    "postgres": "3.4.4"
  }
}
