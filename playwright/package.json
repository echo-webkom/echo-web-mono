{
  "name": "@echo-webkom/playwright",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test:e2e": "pnpm with-env playwright test",
    "test:e2e:ui": "pnpm with-env playwright test --ui-port 5555",
    "test:install": "playwright install --with-deps",
    "test:report": "playwright show-report",
    "clean": "rm -rf node_modules playwright-report test-results .turbo",
    "with-env": "dotenv -e ../.env --",
    "check": "oxlint tests && oxfmt --check .",
    "check:fix": "oxlint tests --fix && oxfmt ."
  },
  "dependencies": {
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@playwright/test": "1.58.1",
    "@types/node": "22.19.7",
    "dotenv-cli": "11.0.0",
    "postgres": "3.4.8",
    "typescript": "5.9.3"
  }
}
