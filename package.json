{
  "name": "echo-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "./check.sh && turbo run dev --filter=@echo-webkom/web --filter=@echo-webkom/cms --filter=@echo-webkom/uno --filter=@echo-webkom/db",
    "dev:all": "./check.sh && turbo run dev",
    "web:dev": "pnpm run --filter=web dev",
    "cms:dev": "pnpm run --filter=cms dev",
    "db:dev": "pnpm run --filter=db dev",
    "start": "turbo run start",
    "setup": "pnpm install && pnpm db:up && pnpm db:migrate",
    "clean": "rm -rf node_modules .turbo",
    "clean-workspaces": "turbo run clean",
    "db:generate": "pnpm --filter=db db:generate",
    "db:migrate": "pnpm --filter=db db:migrate",
    "db:check": "pnpm --filter=db db:check",
    "db:reset": "pnpm --filter=db db:reset",
    "db:up": "docker compose --profile dev up -d",
    "db:down": "docker compose --profile dev down",
    "db:remove": "docker compose --profile dev down --rmi all -v",
    "db:setup": "pnpm db:remove && pnpm db:up && pnpm sleep2s && pnpm db:migrate",
    "seed": "pnpm --filter=seeder seed:start",
    "sleep2s": "node -e \"setTimeout(() => process.exit(0), 2000)\"",
    "email:preview": "pnpm --filter=email preview",
    "lint": "echo 'Use pnpm check or pnpm check:fix instead'",
    "lint:fix": "echo 'Use pnpm check or pnpm check:fix instead'",
    "format": "echo 'Use pnpm check or pnpm check:fix instead'",
    "format:check": "echo 'Use pnpm check or pnpm check:fix instead'",
    "typecheck": "echo 'Use pnpm check or pnpm check:fix instead'",
    "check": "turbo run check",
    "check:fix": "turbo run check:fix",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:ui": "turbo run test:e2e:ui",
    "test:e2e:docker": "./scripts/run-tests.sh --build",
    "extract": "pnpm --filter=cms extract",
    "typegen": "pnpm --filter=cms typegen",
    "tools:install": "pnpm --filter=uno tools:install"
  },
  "dependencies": {
    "turbo": "2.8.12",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0"
  },
  "packageManager": "pnpm@10.20.0"
}
