{
  "name": "@echo-webkom/db",
  "version": "0.1.0",
  "exports": {
    "./schemas": "./src/schemas/index.ts",
    "./utils": "./src/utils.ts",
    "./create": "./src/create.ts",
    "./serverless": "./src/serverless.ts",
    "./error": "./src/error.ts"
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "lint": "deno lint src",
    "db:generate": "deno run --env-file ../../.env -A npm:drizzle-kit generate",
    "db:migrate": "deno run --env-file ../../.env -A ./drizzle/migrate.ts",
    "db:check": "deno run --env-file ../../.env -A npm:drizzle-kit check && denp run -A ./drizzle/check.ts",
    "kit:up": "deno run -A npm:drizzle-kit up",
    "dev": "deno run -A npm:drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "0.33.0",
    "drizzle-zod": "0.5.1",
    "nanoid": "5.0.7",
    "next-auth": "4.24.7",
    "pg": "8.13.0",
    "postgres": "3.4.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.24.2"
  }
}
