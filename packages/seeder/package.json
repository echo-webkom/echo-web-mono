{
  "name": "@echo-webkom/seeder",
  "version": "0.1.0",
  "main": "./src/index.ts",
  "scripts": {
    "seed:start": "pnpm with-env tsx ./src/index.ts",
    "clean": "rm -rf .turbo node_modules",
    "with-env": "dotenv -e ../../.env --",
    "check": "oxlint . && oxfmt --check . && tsc --noEmit",
    "check:fix": "oxlint . --fix && oxfmt . && tsc --noEmit"
  },
  "dependencies": {
    "@echo-webkom/db": "workspace:*",
    "@echo-webkom/lib": "workspace:*",
    "@faker-js/faker": "10.2.0",
    "@sanity/client": "7.14.1",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "drizzle-orm": "0.45.1",
    "groq": "5.7.0"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "dotenv-cli": "11.0.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
