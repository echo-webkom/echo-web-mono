{
  "name": "@echo-webkom/cms",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "sanity"
  ],
  "type": "module",
  "exports": {
    "./types": "./sanity.types.ts"
  },
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "extract": "sanity schema extract --enforce-required-fields",
    "typegen": "sanity typegen generate",
    "clean": "rm -rf node_modules .sanity dist",
    "deploy-graphql": "sanity graphql deploy",
    "check": "oxlint . && oxfmt --check . && tsc --noEmit",
    "check:fix": "oxlint . --fix && oxfmt . && tsc --noEmit"
  },
  "dependencies": {
    "@echo-webkom/lib": "workspace:*",
    "@sanity/client": "7.15.0",
    "@sanity/color-input": "6.0.4",
    "@sanity/icons": "3.7.4",
    "@sanity/ui": "3.1.11",
    "@sanity/vision": "5.11.0",
    "nanoid": "5.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "19.2.4",
    "sanity": "5.11.0",
    "sanity-plugin-markdown": "8.0.5",
    "sanity-plugin-media": "4.1.1",
    "sanity-plugin-singleton-tools": "^1.1.0",
    "slugify": "1.6.6",
    "styled-components": "6.3.8"
  },
  "devDependencies": {
    "@types/react": "19.2.9",
    "@types/styled-components": "5.1.36",
    "dotenv": "17.2.3",
    "typescript": "5.9.3"
  }
}
