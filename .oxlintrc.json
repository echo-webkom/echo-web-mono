{
  "plugins": [
    "typescript",
    "react",
    "react-hooks"
  ],
  "rules": {
    "eqeqeq": "error",
    "no-console": [
      "warn",
      {
        "allow": [
          "warn",
          "error",
          "info"
        ]
      }
    ],
    "typescript/prefer-optional-chain": "error",
    "typescript/prefer-nullish-coalescing": "error",
    "typescript/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ],
    "typescript/consistent-type-imports": [
      "error",
      {
        "prefer": "type-imports",
        "fixStyle": "inline-type-imports"
      }
    ],
    "typescript/array-type": [
      "error",
      {
        "default": "generic",
        "readonly": "generic"
      }
    ]
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/.next",
    "**/.sanity",
    "**/.astro",
    "**/build",
    "**/out",
    "**/playwright-report",
    "**/test-results"
  ]
}
